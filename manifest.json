{
   "manifest_version": 3,
   "name": "Atlantean Mermaid",
   "description": "Renders Mermaid diagram blocks in Bitbucket and Confluence.",
   "version": "2.0.0",
   "icons": {
      "128": "icons/icon-128.png",
      "48": "icons/icon-48.png"
   },
   "content_scripts": [ {
      "css": [ "styles.css" ],
      "js": [ "vendor/mermaid.min.js", "content-script.js" ],
      "matches": [ 
         "https://bitbucket.org/*", 
         "https://*.atlassian.net/wiki/*" 
      ],
      "run_at": "document_idle"
   } ],
   "host_permissions": [ 
      "https://bitbucket.org/*", 
      "https://*.atlassian.net/wiki/*" 
   ]
}
